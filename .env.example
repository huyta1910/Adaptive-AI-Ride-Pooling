PROJECT_NAME=Adaptive AI Ride Pooling
ENVIRONMENT=local
POSTGRES_DB=adaptive_ride_pooling
POSTGRES_USER=adaptive_user
POSTGRES_PASSWORD=adaptive_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://adaptive_user:adaptive_password@db:5432/adaptive_ride_pooling
BACKEND_CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Real road routing (VietMap Route API). Leave VIETMAP_API_KEY empty to fall
# back to the straight-line mock polyline (no real distance/duration).
ROUTING_ENABLED=true
VIETMAP_API_KEY=
VIETMAP_ROUTE_URL=https://maps.vietmap.vn/api/route
ROUTING_TIMEOUT_SECONDS=4.0
